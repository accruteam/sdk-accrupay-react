{
  "name": "@accrupay/react-workspace",
  "license": "MIT",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "sdk",
    "playground"
  ],
  "scripts": {
    "build": "yarn workspace @accrupay/react build",
    "dev": "yarn workspace playground dev",
    "lint": "yarn workspaces run lint",
    "codegen": "yarn workspace @accrupay/react codegen",
    "codegen:watch": "yarn workspace @accrupay/react codegen:watch",
    "clean": "yarn workspaces run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "yarn workspace @accrupay/react build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.33.0",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.6",
    "lint-staged": "^16.2.6",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "slackify-markdown": "^5.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.39.1"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
